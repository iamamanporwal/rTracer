{
  "name": "trace",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-native motorsport sandbox — hub world + addressable zones + player passport.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@trace/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @trace/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "trace": "pnpm --filter @trace/asset-cli exec tsx src/cli.ts",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "turbo": "2.1.3",
    "typescript": "5.6.3",
    "prettier": "3.3.3",
    "eslint": "9.13.0",
    "@eslint/js": "9.13.0",
    "typescript-eslint": "8.11.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "globals": "15.11.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,html,css}": [
      "prettier --write"
    ]
  }
}
